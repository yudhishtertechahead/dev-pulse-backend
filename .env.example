NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME
JWT_ACCESS_SECRET=replace-with-random-32-plus-char-string
JWT_REFRESH_SECRET=replace-with-different-random-32-plus-char-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:3001
FRONTEND_URL=http://localhost:3001

# Admin seed — used only by: npm run seed:admin
# Never commit real values. Set these in your actual .env
ADMIN_NAME=admin
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@123
